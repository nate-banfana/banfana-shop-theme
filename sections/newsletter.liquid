<section class="newsletter"><div class="wrap">
  <h2>{{ section.settings.heading }}</h2>
  <p class="muted" style="max-width:46ch;margin:8px auto 0">{{ section.settings.text }}</p>
  {% form 'customer' %}<input type="email" name="contact[email]" placeholder="you@email.com" aria-label="Email"><button class="btn" type="submit">Sign up</button>{% endform %}
</div></section>
{% schema %}
{ "name":"Newsletter","settings":[
  {"type":"text","id":"heading","label":"Heading","default":"Get the drop (of software updates)."},
  {"type":"textarea","id":"text","label":"Text","default":"We mostly ship product-feed improvements, occasionally merch."}],
  "presets":[{"name":"Newsletter"}] }
{% endschema %}
