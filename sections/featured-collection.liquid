<div class="wrap"><div class="section">
  <div class="section-head"><div><h2>{{ section.settings.heading }}</h2>{%- if section.settings.sub != blank -%}<p>{{ section.settings.sub }}</p>{%- endif -%}</div><a class="muted" href="{{ section.settings.collection.url | default: routes.all_products_collection_url }}" style="font-size:14px">View all &rarr;</a></div>
  <div class="grid">
    {%- assign coll = section.settings.collection -%}
    {%- if coll != blank -%}
      {%- for product in coll.products limit: section.settings.count -%}{% render 'card-product', product: product %}{%- endfor -%}
    {%- else -%}
      {%- for product in collections.all.products limit: section.settings.count -%}{% render 'card-product', product: product %}{%- endfor -%}
    {%- endif -%}
  </div>
</div></div>
{% schema %}
{ "name":"Featured collection","settings":[
  {"type":"text","id":"heading","label":"Heading","default":"The Collection"},
  {"type":"text","id":"sub","label":"Subheading","default":"15 products we made up, enriched to look like we mean it."},
  {"type":"collection","id":"collection","label":"Collection"},
  {"type":"range","id":"count","label":"Products","min":4,"max":16,"step":1,"default":8}],
  "presets":[{"name":"Featured collection"}] }
{% endschema %}
