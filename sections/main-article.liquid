<article class="wrap" style="max-width:760px;margin:0 auto">
  <div class="crumbs"><a href="{{ routes.root_url }}">Home</a> / <a href="{{ blog.url }}">{{ blog.title }}</a> / {{ article.title }}</div>
  <div class="section" style="padding-top:22px">
    <span class="eyebrow">{{ article.published_at | date: '%B %d, %Y' }}{% if article.author != blank %} · {{ article.author }}{% endif %}</span>
    <h1 style="font-size:clamp(28px,4vw,40px);margin:12px 0 18px">{{ article.title }}</h1>
    {%- if article.image -%}<img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" style="width:100%;border-radius:var(--radius);border:1px solid var(--border);margin-bottom:26px">{%- endif -%}
    <div class="article-body" style="font-size:16.5px;line-height:1.75;color:#dcdce2">{{ article.content }}</div>
    <div style="border-top:1px solid var(--border);margin-top:36px;padding-top:22px"><a href="{{ blog.url }}" class="muted">&larr; Back to {{ blog.title }}</a></div>
  </div>
</article>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BlogPosting","headline":{{ article.title | json }},"datePublished":{{ article.published_at | date: '%Y-%m-%d' | json }},"dateModified":{{ article.updated_at | date: '%Y-%m-%d' | json }},"author":{"@type":"Organization","name":"Banfana"},"publisher":{"@type":"Organization","name":{{ shop.name | json }}},{% if article.image %}"image":"https:{{ article.image | image_url: width: 1200 }}",{% endif %}"mainEntityOfPage":{{ article.url | prepend: shop.url | json }},"description":{{ article.excerpt_or_content | strip_html | truncate: 155 | json }}}
</script>
<style>.article-body h2{font-size:24px;margin:30px 0 12px}.article-body h3{font-size:19px;margin:24px 0 10px}.article-body p{margin:0 0 16px}.article-body ul,.article-body ol{margin:0 0 16px;padding-left:22px}.article-body li{margin-bottom:6px}.article-body a{color:var(--brand)}.article-body img{max-width:100%;border-radius:12px;margin:16px 0}.article-body blockquote{border-left:3px solid var(--brand);margin:20px 0;padding:4px 0 4px 18px;color:var(--muted)}</style>
{% schema %}
{ "name":"Article","settings":[],"enabled_on":{"templates":["article"]} }
{% endschema %}
