<div class="wrap"><div class="section">
  <div class="section-head"><div><h2>Search</h2></div></div>
  <form action="{{ routes.search_url }}" method="get" style="margin-bottom:24px"><input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products" style="width:100%;background:var(--bg2);border:1px solid var(--border);color:var(--text);border-radius:12px;padding:14px"></form>
  {%- if search.performed -%}
    <p class="muted" style="margin-bottom:18px">{{ search.results_count }} result{{ search.results_count | pluralize: '','s' }} for &ldquo;{{ search.terms }}&rdquo;</p>
    <div class="grid">
      {%- for item in search.results -%}{%- if item.object_type == 'product' -%}{% render 'card-product', product: item %}{%- endif -%}{%- else -%}<p class="muted">No results.</p>{%- endfor -%}
    </div>
  {%- endif -%}
</div></div>
{% schema %}
{ "name":"Search","settings":[],"enabled_on":{"templates":["search"]} }
{% endschema %}
