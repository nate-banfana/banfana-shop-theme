<div class="wrap"><div class="section">
  <div class="section-head"><div><h2>{{ section.settings.heading }}</h2>{%- if section.settings.sub != blank -%}<p>{{ section.settings.sub }}</p>{%- endif -%}</div></div>
  <div class="cats">
    {%- for block in section.blocks -%}
      {%- assign img = '' -%}
      {%- if block.settings.image != blank -%}{%- assign img = block.settings.image | image_url: width: 800 -%}
      {%- elsif block.settings.asset != blank -%}{%- assign img = block.settings.asset | asset_url -%}
      {%- elsif block.settings.collection.featured_image -%}{%- assign img = block.settings.collection.featured_image | image_url: width: 800 -%}{%- endif -%}
      <a class="cat" href="{{ block.settings.collection.url | default: block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
        {%- if img != blank -%}<img src="{{ img }}" alt="{{ block.settings.label }}">{%- endif -%}
        <span class="lbl">{{ block.settings.collection.title | default: block.settings.label }}<small>{{ block.settings.sub }}</small></span>
      </a>
    {%- endfor -%}
  </div>
</div></div>
{% schema %}
{ "name":"Collection list","settings":[
  {"type":"text","id":"heading","label":"Heading","default":"Shop by category"},
  {"type":"text","id":"sub","label":"Subheading"}],
  "blocks":[{"type":"cat","name":"Tile","settings":[
    {"type":"collection","id":"collection","label":"Collection (optional)"},
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"text","id":"asset","label":"Theme asset fallback"},
    {"type":"text","id":"label","label":"Label"},
    {"type":"text","id":"sub","label":"Small caption"},
    {"type":"url","id":"link","label":"Link"}]}],
  "presets":[{"name":"Collection list"}] }
{% endschema %}
