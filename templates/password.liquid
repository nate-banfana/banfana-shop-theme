<div class="pw"><div>
  <img src="{{ 'banfana-wordmark-white.png' | asset_url }}" alt="{{ shop.name }}">
  <h1 style="font-size:26px">Opening soon.</h1>
  <p class="muted" style="max-width:44ch;margin:10px auto 0">{% if shop.password_message != blank %}{{ shop.password_message }}{% else %}A preview of the Banfana Supply collection. Enter the password to look around.{% endif %}</p>
  {% form 'storefront_password' %}
    {{ form.errors | default_errors }}
    <input type="password" name="password" placeholder="Enter password" autofocus>
    <button type="submit" class="btn">Enter</button>
  {% endform %}
  <p class="muted" style="margin-top:20px;font-size:12px">Are you the store owner? <a href="/admin" style="color:var(--brand)">Log in</a></p>
</div></div>
